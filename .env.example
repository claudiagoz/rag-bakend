# Base de datos — copiar desde Supabase → botón "Connect" → pestaña ORMs → Prisma
DATABASE_URL="postgresql://postgres.ref:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.ref:password@aws-0-region.pooler.supabase.com:5432/postgres"
SUPABASE_PROJECT_REF="ref-de-tu-proyecto-supabase"
SUPABASE_DB_PASSWORD="password-de-la-db-de-supabase"

# JWT
JWT_SECRET="un-string-largo-y-aleatorio-de-al-menos-32-chars"

# OpenAI
OPENAI_API_KEY="sk-..."

# Email (Resend.com como SMTP)
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend"
SMTP_PASS="re_..."
SMTP_FROM="noreply@tudominio.com"
SUPERADMIN_EMAIL="tu@email.com"

# Supabase
SUPABASE_URL="https://xyzcompany.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." # Settings → API → service_role

# App
APP_URL="http://localhost:3000"
NODE_ENV="development"
PORT="3000"

# CORS — dominios permitidos, separados por coma. Sin esto, cae a "*" (abierto a cualquier origen)
ALLOWED_ORIGINS="https://tudominio.com,https://app.tudominio.com"

# Mercado Pago — Panel de desarrolladores → Tus integraciones → Credenciales
MERCADOPAGO_ACCESS_TOKEN="APP_USR-... (o TEST-... en modo prueba)"
MERCADOPAGO_PUBLIC_KEY="APP_USR-... (o TEST-... en modo prueba)"
MERCADOPAGO_WEBHOOK_SECRET="secret-configurado-al-crear-el-webhook"

# Trial gratis en días (opcional, default 15)
TRIAL_DAYS="15"

# Redis — revocación de tokens de impersonación (Railway: agregar plugin Redis y copiar la variable REDIS_URL que genera)
REDIS_URL="redis://default:password@host:6379"

# Sentry — monitoreo de errores (sentry.io → crear proyecto Node → copiar el DSN)
# Si se deja vacío, el servidor arranca igual pero sin reportar errores
SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
