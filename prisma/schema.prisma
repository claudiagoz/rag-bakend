// ============================================================
// RAG Multiempresa — Schema Prisma
// Base de datos: Supabase PostgreSQL
// Vectores:      pgvector (extensión nativa de Supabase)
// Storage:       Supabase Storage
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ------------------------------------------------------------
// TENANTS
// ------------------------------------------------------------
model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique        // "acme" → prefijo en Storage + filtro en chunks
  name      String
  plan      Plan     @default(GRATIS)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Suscripción / Mercado Pago
  subscriptionStatus  SubscriptionStatus @default(TRIALING)
  trialStartedAt      DateTime?
  trialEndsAt         DateTime?
  mpPayerId           String?
  mpPreapprovalId     String?
  mpPreapprovalStatus String?
  lastPaymentAt       DateTime?
  lastPaymentFailedAt DateTime?

  botConfig         BotConfig?
  users             User[]
  documents         Document[]
  apiKeys           ApiKey[]
  usageLogs         UsageLog[]
  sessions          ChatSession[]
  auditLogs         AuditLog[]
  subscriptionEvents SubscriptionEvent[]

  @@index([mpPreapprovalId])
  @@map("tenants")
}

enum Plan {
  GRATIS        // trial 15 días — 100 conversaciones, hasta 5 fuentes de conocimiento
  EMPRENDEDORES // $150.000/mes — 300 conversaciones/mes, hasta 10 fuentes de conocimiento
  PYMES         // $300.000/mes — 1.000 conversaciones/mes, hasta 30 fuentes de conocimiento
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

// ------------------------------------------------------------
// BOT CONFIG — personalización por empresa
// ------------------------------------------------------------
model BotConfig {
  id                  String  @id @default(cuid())
  tenantId            String  @unique
  tenant              Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  systemPrompt        String  @db.Text
  botName             String  @default("Asistente")
  welcomeMessage      String  @db.Text @default("Hola, ¿en qué te puedo ayudar?")
  model               String  @default("gpt-4o")
  temperature         Float   @default(0.2)
  maxTokens           Int     @default(1024)
  chunkSize           Int     @default(512)
  chunkOverlap        Int     @default(64)
  topK                Int     @default(5)
  similarityThreshold Float   @default(0.75)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bot_configs")
}

// ------------------------------------------------------------
// USERS
// ------------------------------------------------------------
model User {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email        String
  name         String?
  role         UserRole  @default(VIEWER)
  passwordHash String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions ChatSession[]

  @@unique([tenantId, email])
  @@map("users")
}

enum UserRole {
  VIEWER
  EDITOR
  ADMIN
  SUPERADMIN
}

// ------------------------------------------------------------
// DOCUMENTS
// ------------------------------------------------------------
model Document {
  id           String         @id @default(cuid())
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  filename     String
  originalName String
  mimeType     String
  sizeBytes    Int
  // Ruta en Supabase Storage: "tenant-slug/document-id/filename.pdf"
  storagePath  String
  status       DocumentStatus @default(PENDING)
  errorMessage String?        @db.Text
  chunkCount   Int?
  uploadedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks DocumentChunk[]

  @@index([tenantId, status])
  @@map("documents")
}

enum DocumentStatus {
  PENDING
  PROCESSING
  INDEXED
  FAILED
  DELETED
}

// ------------------------------------------------------------
// DOCUMENT CHUNKS — reemplaza Pinecone completamente
// Los vectores se almacenan en pgvector dentro de Supabase
// ------------------------------------------------------------
model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tenantId   String   // denormalizado: permite filtrar por tenant sin JOIN

  content    String   @db.Text
  // vector(1536) = dimensiones de text-embedding-3-small de OpenAI
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int
  page       Int?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([documentId])
  @@map("document_chunks")
}

// ------------------------------------------------------------
// API KEYS
// ------------------------------------------------------------
model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name       String
  keyHash    String    @unique
  keyPrefix  String
  scopes     String[]  @default(["chat"])
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@map("api_keys")
}

// ------------------------------------------------------------
// CHAT SESSIONS
// ------------------------------------------------------------
model ChatSession {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  ChatMessage[]
  usageLogs UsageLog[]

  @@index([tenantId])
  @@map("chat_sessions")
}

// ------------------------------------------------------------
// CHAT MESSAGES
// ------------------------------------------------------------
model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role       MessageRole
  content    String      @db.Text
  sources    Json?       // [{ documentId, filename, page, score }]
  tokensUsed Int?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("chat_messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ------------------------------------------------------------
// USAGE LOGS — billing y analítica por tenant
// ------------------------------------------------------------
model UsageLog {
  id         String       @id @default(cuid())
  tenantId   String
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessionId  String?
  session    ChatSession? @relation(fields: [sessionId], references: [id])

  action     UsageAction
  tokensIn   Int          @default(0)
  tokensOut  Int          @default(0)
  durationMs Int?
  model      String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@map("usage_logs")
}

enum UsageAction {
  CHAT_QUERY
  DOC_INGEST
  DOC_DELETE
  EMBED_QUERY
}

// ------------------------------------------------------------
// AUDIT LOG — registro inmutable de acciones del super admin
// y eventos críticos del sistema (impersonación, bloqueos, alertas)
// ------------------------------------------------------------
model AuditLog {
  id              String    @id @default(cuid())
  
  // Quién ejecutó la acción (null = sistema automático)
  adminId         String?

  // Acción realizada
  action          AuditAction

  // Tenant afectado (null = acción global)
  targetTenantId  String?
  targetTenant    Tenant?   @relation(fields: [targetTenantId], references: [id])

  // Datos extra según el action
  metadata        Json?

  createdAt       DateTime  @default(now())

  @@index([targetTenantId, action])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditAction {
  // Impersonación
  IMPERSONATE_START
  IMPERSONATE_END

  // Gestión de tenants
  TENANT_CREATED
  TENANT_SUSPENDED
  TENANT_REACTIVATED
  TENANT_PLAN_CHANGED
  BOT_CONFIG_UPDATED

  // Uso y billing
  USAGE_ALERT_80      // aviso al 80%
  USAGE_ALERT_95      // aviso al 95%
  USAGE_ALERT_100     // aviso al 100% (bloqueado)
  USAGE_BLOCKED       // request bloqueado por cuota
  DOC_LIMIT_BLOCKED   // upload bloqueado por límite de documentos del plan

  // Documentos (acción de admin)
  DOC_UPLOADED_BY_ADMIN
  DOC_DELETED_BY_ADMIN

  // Suscripción / Mercado Pago
  SIGNUP_COMPLETED
  SUBSCRIPTION_ACTIVATED
  SUBSCRIPTION_PAYMENT_FAILED
  SUBSCRIPTION_CANCELLED
  TRIAL_EXPIRED_BLOCKED
}

// ------------------------------------------------------------
// SUBSCRIPTION EVENTS — log crudo de cada webhook de Mercado Pago
// (separado de AuditLog: alto volumen, no son acciones de un admin)
// ------------------------------------------------------------
model SubscriptionEvent {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  mpPreapprovalId   String?
  mpNotificationId  String?  @unique // id de la notificación de MP — evita reprocesar reintentos duplicados
  eventType         String
  rawPayload        Json

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("subscription_events")
}
